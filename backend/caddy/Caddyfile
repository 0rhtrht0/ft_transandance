https:// {
  tls /etc/caddy/certs/localhost+2.pem /etc/caddy/certs/localhost+2-key.pem

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "DENY"
    Referrer-Policy "same-origin"
  }

  redir /grafana /grafana/ 308
  redir /prometheus /prometheus/ 308
  redir /alertmanager /alertmanager/ 308

  @grafana path /grafana*
  reverse_proxy @grafana grafana:3000

  @prometheus path /prometheus*
  reverse_proxy @prometheus prometheus:9090

  @alertmanager path /alertmanager*
  reverse_proxy @alertmanager alertmanager:9093

  @avatars path /uploaded_avatars*
  reverse_proxy @avatars backend:8000

  @message_uploads path /uploaded_messages*
  reverse_proxy @message_uploads backend:8000

  @api path /api/* /auth/* /users/* /ws* /openapi.json /docs* /redoc* /health /ready /metrics
  reverse_proxy @api backend:8000

  reverse_proxy frontend:5173
}

http:// {
  redir https://{host}:8443{uri} 308
}
